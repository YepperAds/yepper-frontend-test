# ─────────────────────────────────────────────────────────────
# Yepper Client — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────
 
# Backend URL — change this one line to switch environments
# Development:
# REACT_APP_API_URL=http://localhost:5000
# Production (uncomment when deploying):
REACT_APP_API_URL=https://yepper-backend-test.onrender.com